{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/user/briefed/.briefed/hooks/session-start.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/user/briefed/.briefed/hooks/prompt-submit.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/user/briefed/.briefed/hooks/post-read.js\"",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/user/briefed/.briefed/hooks/post-edit.js\"",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/user/briefed/.briefed/hooks/post-edit.js\"",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/user/briefed/.briefed/hooks/session-stop.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "briefed": {
      "command": "node",
      "args": [
        "/home/user/briefed/dist/cli.js",
        "mcp",
        "--repo",
        "/home/user/briefed"
      ]
    }
  }
}
