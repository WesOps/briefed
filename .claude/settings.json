{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"/opt/homebrew/Cellar/node/23.11.0/bin/node\" \"/Users/wcampbell/briefed/.briefed/hooks/session-start.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": []
  },
  "mcpServers": {
    "briefed": {
      "command": "/opt/node22/bin/node",
      "args": [
        "/home/user/briefed/dist/cli.js",
        "mcp",
        "--repo",
        "/home/user/briefed"
      ]
    }
  }
}
