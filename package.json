{
  "name": "briefed",
  "version": "1.0.0",
  "description": "Adaptive Context Engine — compile your codebase into focused, token-efficient context for AI coding tools",
  "type": "module",
  "bin": {
    "briefed": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "bench": "node dist/cli.js bench",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "context",
    "claude",
    "cursor",
    "copilot",
    "llm",
    "codebase",
    "developer-tools"
  ],
  "author": "Wesley",
  "license": "MIT",
  "homepage": "https://github.com/WesOps/briefed",
  "repository": {
    "type": "git",
    "url": "https://github.com/WesOps/briefed.git"
  },
  "bugs": {
    "url": "https://github.com/WesOps/briefed/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^13.1.0",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.0",
    "minimatch": "^10.0.1",
    "simple-git": "^3.27.0",
    "typescript": "^5.9.3",
    "web-tree-sitter": "^0.24.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.0",
    "vitest": "^4.1.2"
  }
}
